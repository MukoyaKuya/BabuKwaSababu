# Environment variable template for local/deployment configs
# Generate a real .env file from this template and keep secrets out of source control.

# Django secret key (keep this secret in production)
DJANGO_SECRET_KEY=changeme-please-set-a-strong-secret-key

# Debug mode (True for development, False for production)
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (e.g. localhost,127.0.0.1,example.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
